# ============================================================
# GuiGraph 环境配置模板
# ============================================================
# 复制此文件为 .env 并修改对应值
# 或使用环境切换脚本:
#   Windows: switch_env.bat dev|test|prod
#   Python:  python switch_env.py dev|test|prod
# ============================================================

# ===== 应用基础 =====
APP_NAME=GuiGraph
APP_ENV=dev
DEBUG=true
SECRET_KEY=CHANGE-THIS-IN-PRODUCTION-USE-STRONG-SECRET-KEY

# ===== 数据库 =====
# 开发: sqlite+aiosqlite:///:memory:
# 测试: sqlite+aiosqlite:///:memory:
# 生产: oracle+oracledb://user:pass@host:1521/service_name
DATABASE_URL=sqlite+aiosqlite:///:memory:
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ===== JWT =====
JWT_SECRET_KEY=CHANGE-THIS-IN-PRODUCTION-USE-STRONG-SECRET-KEY
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=120
JWT_REFRESH_EXPIRE_DAYS=7

# ===== 微信 OAuth =====
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_REDIRECT_URI=http://localhost:10011/api/v1/auth/wechat/callback

# ===== MinIO =====
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false

# ===== RAGFlow =====
RAGFLOW_URL=http://localhost:8080
RAGFLOW_API_KEY=

# ===== GraphRAG =====
GRAPH_RAG_URL=http://localhost:8081

# ===== Jenkins =====
JENKINS_DEFAULT_URL=http://localhost:8080/jenkins
JENKINS_DEFAULT_TOKEN=

# ===== CORS =====
CORS_ORIGINS=["http://localhost:10010", "http://localhost:3000", "http://127.0.0.1:10010"]

# ===== 日志 =====
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
