# ===== 开发环境配置 =====
APP_NAME=GuiGraph
APP_ENV=dev
DEBUG=true
SECRET_KEY=dev-secret-key-change-in-production

# ===== 数据库 =====
# 开发用 SQLite 内存数据库
DATABASE_URL=sqlite+aiosqlite:///./guigraph.db
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# ===== JWT =====
JWT_SECRET_KEY=dev-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=120
JWT_REFRESH_EXPIRE_DAYS=7

# ===== 微信 OAuth =====
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_REDIRECT_URI=http://localhost:10011/api/v1/auth/wechat/callback

# ===== MinIO =====
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false

# ===== RAGFlow =====
RAGFLOW_URL=http://localhost:8080
RAGFLOW_API_KEY=

# ===== GraphRAG =====
GRAPH_RAG_URL=http://localhost:8081

# ===== Jenkins =====
JENKINS_DEFAULT_URL=http://localhost:8080/jenkins
JENKINS_DEFAULT_TOKEN=

# ===== CORS =====
CORS_ORIGINS=["http://localhost:10010", "http://localhost:3000"]

# ===== 日志 =====
LOG_LEVEL=DEBUG
LOG_FILE=logs/app.log
